# Environment files with secrets
.env
.env.local
.env.*.local

# Database dumps (contain sensitive data)
*.sql
teatime_dump.sql

# Docker volumes data
mysql-data/
redis-data/
vector-db/

# Python AI service data
python-service/data/

# Logs directory
logs/
*.log

# Build artifacts
*.tar.gz
*.zip

# IDE - IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws
out/

# IDE - VS Code
.vscode/
*.code-workspace

# IDE - Eclipse
.settings/
.classpath
.project

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Temporary files
*.tmp
*.bak
*.swp
*.swo
*~

